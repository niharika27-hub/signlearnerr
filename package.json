{
  "name": "signlearnerr-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "run:all": "npm run dev:all",
    "run:all:check": "npm run dev:all:check",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:all:check": "node scripts/dev-all.mjs --check-only",
    "modules:seed": "node backend/utils/seedModules.js",
    "modules:import": "node backend/utils/importModuleManifest.js",
    "modules:import:json": "node backend/utils/importModuleManifest.js --file docs/examples/module-manifest.example.json --mode upsert",
    "modules:import:csv": "node backend/utils/importModuleManifest.js --file docs/examples/module-manifest.example.csv --mode upsert",
    "modules:import:dry": "node backend/utils/importModuleManifest.js --file docs/examples/module-manifest.example.json --mode upsert --dry-run",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start"
  }
}
